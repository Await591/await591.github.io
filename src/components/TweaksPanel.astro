---
---

<div class="tweaks-wrap">
  <button
    class="tweaks-toggle"
    id="tweaks-toggle"
    aria-expanded="false"
    aria-controls="tweaks-panel"
  >Tweaks</button>

  <div class="tweaks-panel" id="tweaks-panel" data-open="false">
    <p class="tweaks-title">live display controls</p>

    <div class="tweaks-row">
      <span class="tweaks-label">palette</span>
      <div class="tweaks-options">
        <button class="tweaks-option is-active" data-theme="green">green</button>
        <button class="tweaks-option" data-theme="amber">amber</button>
      </div>
    </div>

    <div class="tweaks-row">
      <span class="tweaks-label">motion</span>
      <div class="tweaks-options">
        <button class="tweaks-option is-active" data-motion="on">on</button>
        <button class="tweaks-option" data-motion="off">off</button>
      </div>
    </div>
  </div>
</div>
