---
const steps = [
  { status: '[....]', label: 'scan display bus' },
  { status: '[....]', label: 'mount profile dataset' },
  { status: '[....]', label: 'link contact endpoints' },
  { status: '[....]', label: 'start public interface' },
];
---

<div class="boot-overlay" id="boot-overlay">
  <div class="boot-card">
    <p class="boot-title">[ SYSTEM INITIALIZATION ]</p>
    <div class="boot-progress" aria-hidden="true">
      <div class="boot-progress-bar" id="boot-progress-bar"></div>
    </div>
    <p class="boot-status" id="boot-status">loading runtime modules...</p>
    <div class="boot-lines" id="boot-lines">
      {steps.map((step) => (
        <div class="boot-line">
          <span class="boot-line-status">{step.status}</span>
          <span>{step.label}</span>
        </div>
      ))}
    </div>
  </div>
</div>
